for (i in names(genelistNCvsC_dreamlet_cellcounts)){for (j in names(genelistNCvsC_dreamlet_cellcounts[[i]])){
  genelistNCvsC_dreamlet_cellcounts[[i]][[paste(j)]]$diffexpressed <- "NO"
  # if log2Foldchange > 0.2 and pvalue < 0.05, set as "UP" 
  genelistNCvsC_dreamlet_cellcounts[[i]][[j]]$diffexpressed[genelistNCvsC_dreamlet_cellcounts[[i]][[j]]$logFC > 0 & genelistNCvsC_dreamlet_cellcounts[[i]][[j]]$P.Value < 0.05] <- "UP"
  # if log2Foldchange < -0.2 and pvalue < 0.05, set as "DOWN"
  genelistNCvsC_dreamlet_cellcounts[[i]][[j]]$diffexpressed[genelistNCvsC_dreamlet_cellcounts[[i]][[j]]$logFC < 0 & genelistNCvsC_dreamlet_cellcounts[[i]][[j]]$P.Value < 0.05] <- "DOWN"
  genelistNCvsC_dreamlet_cellcounts[[i]][[j]]$CNVgene <- 'FALSE'
  genelistNCvsC_dreamlet_cellcounts[[i]][[j]]$CNVgene[rownames(genelistNCvsC_dreamlet_cellcounts[[i]][[j]]) %in% dreamlet_CNVgenes[[j]]$Gene.name] <- 'TRUE'
}}

