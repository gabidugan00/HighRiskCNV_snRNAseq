DEG_dream <- list()
DEG_count<- list()
for (i in names(genelistNCvsC_dreamlet)){for(j in names(genelistNCvsC_dreamlet[[i]])){
  print(i)
  print(j)
  DEG_dream[[i]][[j]] <- subset(genelistNCvsC_dreamlet[[i]][[j]], diffexpressed != "NO")
  DEG_dream[[i]][[j]]$Key <- paste(DEG_dream[[i]][[j]]$diffexpressed,DEG_dream[[i]][[j]]$fdr_0.1, sep = "_")
  DEG_dream[[i]][[j]] <- DEG_dream[[i]][[j]] %>%
    dplyr::group_by(Key)%>%
    dplyr::count()
  DEG_dream[[i]][[j]]$celltype <- i
  DEG_dream[[i]][[j]]$group <-j
}
  DEG_count[[i]] <- do.call(rbind, Map(data.frame, DEG_dream[[i]]))
}

DEG_dream_merge <- do.call(rbind, Map(data.frame,DEG_count))
library(plyr)
DEG_dream_merge$Key <- revalue(DEG_dream_merge$Key, c("DOWN_FALSE"="Downregulated", "DOWN_TRUE"="Downregulated (FDR <0.1)","UP_FALSE" ="Upregulated","UP_TRUE"="Upregulated (FDR<0.1)"))
dput(levels(as.factor(DEG_dream_merge$group)))
DEG_dream_merge$group <- factor(DEG_dream_merge$group,levels = c("CNV22q11.2 del", "CNV22q11.2 dup","CNV16p11.2 del", "CNV16p11.2 dup", "CNV7q11.23 WBS del","CNV1q21.1 del", "CNV1q21.1 dup","CNV15q11.2 BP1-2 del", "CNV15q11.2 BP1-2 dup"))
library(ggplot2)
png("dreamlet_barplot_FDR.png", width = 2500, height = 1300, res = 240)
ggplot2::ggplot(data = DEG_dream_merge, aes(celltype, n, fill = Key)) +
  geom_bar(position = "stack", stat="identity")+
  scale_fill_manual(values=c("dodgerblue","dodgerblue4","firebrick1","firebrick3"))+
  labs(title = "Dreamlet Results by CNV", subtitle = "~CNV+(1|Region)+(1|MG)+(1|HBCC_BrNum)",
       y = "Count of DEGs") + 
  coord_flip()+
  facet_wrap(~ group,ncol=4)+
  theme(plot.title = element_text(hjust = 0.5), plot.subtitle = element_text(hjust=0.5))
dev.off()

