  fgsea_refrmt[[i]] <- list(fgseaRes$Inhibitory_CGE[[paste(i)]],fgseaRes$Inhibitory_MGE[[paste(i)]],fgseaRes$L2_3Excitatory[[paste(i)]],fgseaRes$L5_6Excitatory[[paste(i)]],fgseaRes$Astrocyte[[paste(i)]],fgseaRes$Microglia[[paste(i)]],fgseaRes$Oligodendrocytes[[paste(i)]],fgseaRes$OPC[[paste(i)]],fgseaRes$VLMC_Endo[[paste(i)]])
  names(fgsea_refrmt[[i]]) <- names(fgseaRes)
}

