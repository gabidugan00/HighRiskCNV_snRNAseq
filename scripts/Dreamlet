res.dl_numberofcells<- readRDS("/data/HGBomics/GabiDugan/SNCNV_data_AdditionalSeqDec2022/February2023_Pipeline/scDblFinder/Adults/AfterDoubletRemoval/Harmony_MG/FilterClusters_PercentMT2_5/Harmony_MG/FilterClusters_PercentMT2/Harmony_MG/DifferentialGeneExpression/Dreamlet/DropSample30/Removed_MT_RiboGenes/~CNV+Number.of.Cells.Celltype +(1|Region)+(1|HBCC_BrNum)+(1|Match_group)/res.dl_numberofcells")

res_zenith<- list()
for(i in coefNames(res.dl_numberofcells)[2:12]){
  res_zenith[[i]] = zenith_gsa(res.dl_numberofcells, coef = paste(i), go.gs)
}

saveRDS(res_zenith,"/data/HGBomics/GabiDugan/SNCNV_data_AdditionalSeqDec2022/February2023_Pipeline/scDblFinder/Adults/AfterDoubletRemoval/Harmony_MG/FilterClusters_PercentMT2_5/Harmony_MG/FilterClusters_PercentMT2/Harmony_MG/DifferentialGeneExpression/Dreamlet/DropSample30/Removed_MT_RiboGenes/~CNV+Number.of.Cells.Celltype +(1|Region)+(1|HBCC_BrNum)+(1|Match_group)/res_zenith")

df <- list()
for(i in names(res_zenith)){
  # get genesets with FDR < 5%
  gs = unique(res_zenith[[i]]$Geneset[res_zenith[[i]]$FDR < 0.1])
  # keep only results of these genesets 
  df[[i]] = res_zenith[[i]][res_zenith[[i]]$Geneset %in% gs,]
  # plot results, but with no limit based on the highest/lowest t-statistic
}

names(df)
for(i in names(df)){
  if(nrow(df[[i]])>0){
  # plot results, but with no limit based on the highest/lowest t-statistic
  png(paste(i,"zenith_results.png"), width = 800, height = 1000, res = 100)
  plot1 <- plotZenithResults(df[[i]])+
    labs(caption = "FDR <0.10 Terms, (FDR <0.05 *)")+
    ggtitle(label = paste(i), subtitle = "~CNV + celltype.prop+ (1|Region) \n + (1 | HBCC_BrNum) + (1 | Match_group)")+
    theme(plot.title = element_text(hjust = 0))
  grid.arrange(plot1)
  dev.off()
  }
}

df <- list()
for(i in names(res_zenith)){
  # get genesets with FDR < 10%
  gs = "GO0042775: mitochondrial ATP synthesis coupled electron transport"
  # keep only results of these genesets 
  df[[i]] = res_zenith[[i]][res_zenith[[i]]$Geneset %in% gs,]
  # create t-statisitc 
  df[[i]]$t = df[[i]]$delta/df[[i]]$se
}

df <- list()
fgsea_celltype <- list()
for(i in names(fgseaRes)){for(j in names(fgseaRes[[i]])){
  # get genesets with FDR < 10%
  gs = "GO0042775: mitochondrial ATP synthesis coupled electron transport"
  # keep only results of these genesets 
  df[[i]][[j]] = fgseaRes[[i]][[j]][fgseaRes[[i]][[j]]$pathway %in% gs,]
  # create t-statisitc 
  df[[i]][[j]]$celltype <- i
  df[[i]][[j]]$CNV <- j
}
  fgsea_celltype[[i]] <- Reduce(rbind,df[[i]])
}
