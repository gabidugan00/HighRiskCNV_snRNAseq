pb_adult_dreamlet_remvd_genes <- readRDS("/data/HGBomics/GabiDugan/SNCNV_data_AdditionalSeqDec2022/February2023_Pipeline/scDblFinder/Adults/AfterDoubletRemoval/Harmony_MG/FilterClusters_PercentMT2_5/Harmony_MG/FilterClusters_PercentMT2/Harmony_MG/DifferentialGeneExpression/Dreamlet/DropSample30/Removed_MT_RiboGenes/pb_adult_dreamlet_remvd_genes")
nrow(pb_adult_dreamlet_remvd_genes@metadata$aggr_means)
celltype_count<- readRDS("/data/HGBomics/GabiDugan/SNCNV_data_AdditionalSeqDec2022/February2023_Pipeline/scDblFinder/Adults/AfterDoubletRemoval/Harmony_MG/FilterClusters_PercentMT2_5/Harmony_MG/FilterClusters_PercentMT2/Harmony_MG/celltype_count")
celltype_count <- celltype_count[-grep("Sample_30", celltype_count$SampleID),]
library(plyr)
celltype_count$Cell.Type <- revalue(celltype_count$Cell.Type, c("CGE-Derived Inhibitory Neurons"="Inhibitory_CGE", "MGE-Derived Inhibitory Neurons"="Inhibitory_MGE","Upper Layer Excitatory Neurons"="L2_3Excitatory","Lower Layer Excitatory Neurons"="L5_6Excitatory"))

pb_adult_dreamlet_remvd_genes@metadata$aggr_means$origident.celltype <- paste(pb_adult_dreamlet_remvd_genes@metadata$aggr_means$orig.ident,pb_adult_dreamlet_remvd_genes@metadata$aggr_means$subclass.annotation, sep = "_")
celltype_count$origident.celltype<- paste(celltype_count$SampleID,celltype_count$Cell.Type, sep = "_")

table(celltype_count$origident.celltype %in% pb_adult_dreamlet_remvd_genes@metadata$aggr_means$origident.celltype)

pb_adult_dreamlet_remvd_genes@metadata$aggr_means$celltype.prop <- celltype_count$celltype_proportion[match(pb_adult_dreamlet_remvd_genes@metadata$aggr_means$origident.celltype,celltype_count$origident.celltype)]

form <- ~CNV + celltype.prop+ (1|Region) + (1 | HBCC_BrNum) + (1 | Match_group)
# Normalize and apply voom/voomWithDreamWeights
res.proc_numberofcells = processAssays(pb_adult_dreamlet_remvd_genes, form)
saveRDS(res.proc_numberofcells,"/data/HGBomics/GabiDugan/SNCNV_data_AdditionalSeqDec2022/February2023_Pipeline/scDblFinder/Adults/AfterDoubletRemoval/Harmony_MG/FilterClusters_PercentMT2_5/Harmony_MG/FilterClusters_PercentMT2/Harmony_MG/DifferentialGeneExpression/Dreamlet/DropSample30/Removed_MT_RiboGenes/Pseudobulking_CellClass/res.proc_numberofcells")
data.frame.counts.remvdgenes <- list()
for(i in names(res.proc_numberofcells)){
  data.frame.counts.remvdgenes[[i]]$Number.of.Genes <- nrow(res.proc_numberofcells[[i]])
  data.frame.counts.remvdgenes[[i]]$Cell.Type <- i
  data.frame.counts.remvdgenes[[i]]$Filtering <- "Dreamlet Default Settings"
}

