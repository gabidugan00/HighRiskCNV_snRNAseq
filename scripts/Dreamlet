excl_var = function(x, var2ex = c("Region","CNV")){
  x=x[!x %in% var2ex]
  return(x)
}

pval_pc_chk<- list()
for(i in names(pca_snCNV_dreamlet)){
  x <- excl_var(colnames(metadata_simple[[i]]))
  pval_pc_chk[[i]]=matrix(ncol=10, nrow=length(x))
  rownames(pval_pc_chk[[i]])=excl_var(colnames(metadata_simple[[i]]))
  colnames(pval_pc_chk[[i]])=paste0("PC",1:10)
}


for(i in names(pca_snCNV_dreamlet)){for (PC in 1:10) {for (k in rownames(pval_pc_chk[[i]])){
  a=residuals(lme4::lmer(data = data.frame(pc=pca_snCNV_dreamlet[[i]]$x[,PC], metadata_simple[[i]]), pc~CNV+(1|BrainNumber)+(1|Region)+ (1|MatchGroup)))
  a=summary(lm(a~metadata_simple[[i]][[k]]))
  pval_pc_chk[[i]][k,PC]=pf(a$fstatistic[1],a$fstatistic[2],a$fstatistic[3],lower.tail=FALSE)[1]
}}}
names(pval_pc_chk) <- c("Astrocyte", "CGE-Derived Inhibitory Neurons", "MGE-Derived Inhibitory Neurons", "Lower Excitatory Neurons", "Upper Excitatory Neurons", "Microglia", "Oligodendrocytes", "OPC", "VLMC_Endo")
sig_cov<- list()
sig_cov_merge<- list()
for(i in names(pval_pc_chk)){
  sig_cov[[i]] <- pval_pc_chk[[i]][,1][pval_pc_chk[[i]][,1]<0.05]
  sig_cov_merge[[i]] <- data.frame(Reduce(rbind,sig_cov[[i]]))
  rownames(sig_cov_merge[[i]]) <- names(sig_cov[[i]])
  colnames(sig_cov_merge[[i]]) <-"Linear.Reg.P.Val"
  sig_cov_merge[[i]]$Celltype <- i
  sig_cov_merge[[i]]$Cov <- rownames(sig_cov_merge[[i]])
}

