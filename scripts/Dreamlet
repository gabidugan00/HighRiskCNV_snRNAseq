genelistNCvsC_dreamlet<- list()
for(i in names(res.dl_defaults_remvdgenes)){for(j in coefNames(res.dl_defaults_remvdgenes)[2:10]){
  print(i)
  genelistNCvsC_dreamlet[[i]][[j]] <- topTable(res.dl_defaults_remvdgenes[[paste(i)]], coef = j, number = Inf)
}}

Genes_inCNVregions <- readRDS("~/Genes_inCNVregions")
dreamlet_CNVgenes <- list(Genes_inCNVregions$HBCC_6_15q11del,Genes_inCNVregions$HBCC_6_15q11del,Genes_inCNVregions$HBCC_2del,Genes_inCNVregions$HBCC_8dup,Genes_inCNVregions$HBCC_1_1q21del,Genes_inCNVregions$HBCC_2_1q21dup,Genes_inCNVregions$SMRI_2_22q11del,Genes_inCNVregions$SMRI_3_22q11dup,Genes_inCNVregions$UMB_2_7q11del)
names(dreamlet_CNVgenes) <- names(genelistNCvsC_dreamlet$Astrocyte)

for (i in names(genelistNCvsC_dreamlet)){for (j in names(genelistNCvsC_dreamlet[[i]])){
  genelistNCvsC_dreamlet[[i]][[paste(j)]]$diffexpressed <- "NO"
  # if log2Foldchange > 0.2 and pvalue < 0.05, set as "UP" 
  genelistNCvsC_dreamlet[[i]][[j]]$diffexpressed[genelistNCvsC_dreamlet[[i]][[j]]$logFC > 0 & genelistNCvsC_dreamlet[[i]][[j]]$P.Value < 0.05] <- "UP"
  # if log2Foldchange < -0.2 and pvalue < 0.05, set as "DOWN"
  genelistNCvsC_dreamlet[[i]][[j]]$diffexpressed[genelistNCvsC_dreamlet[[i]][[j]]$logFC < 0 & genelistNCvsC_dreamlet[[i]][[j]]$P.Value < 0.05] <- "DOWN"
  genelistNCvsC_dreamlet[[i]][[j]]$CNVgene <- 'FALSE'
  genelistNCvsC_dreamlet[[i]][[j]]$CNVgene[rownames(genelistNCvsC_dreamlet[[i]][[j]]) %in% dreamlet_CNVgenes[[j]]$Gene.name] <- 'TRUE'
}}

for (i in names(genelistNCvsC_dreamlet)){for (j in names(genelistNCvsC_dreamlet[[i]])){
  genelistNCvsC_dreamlet[[i]][[paste(j)]]$diffexpressed <- "NO"
  # if log2Foldchange > 0.2 and pvalue < 0.05, set as "UP" 
  genelistNCvsC_dreamlet[[i]][[j]]$diffexpressed[genelistNCvsC_dreamlet[[i]][[j]]$logFC > 0 & genelistNCvsC_dreamlet[[i]][[j]]$P.Value < 0.05] <- "UP"
  # if log2Foldchange < -0.2 and pvalue < 0.05, set as "DOWN"
  genelistNCvsC_dreamlet[[i]][[j]]$diffexpressed[genelistNCvsC_dreamlet[[i]][[j]]$logFC < 0 & genelistNCvsC_dreamlet[[i]][[j]]$P.Value < 0.05] <- "DOWN"
  genelistNCvsC_dreamlet[[i]][[j]]$CNVgene <- 'FALSE'
  genelistNCvsC_dreamlet[[i]][[j]]$CNVgene[rownames(genelistNCvsC_dreamlet[[i]][[j]]) %in% dreamlet_CNVgenes[[j]]$Gene.name] <- 'TRUE'
}
}

for(i in names(genelistNCvsC_dreamlet)){for(j in names(genelistNCvsC_dreamlet[[i]])){
  genelistNCvsC_dreamlet[[i]][[j]]$fdr_0.5 <- 'FALSE'
  genelistNCvsC_dreamlet[[i]][[j]]$fdr_0.5[genelistNCvsC_dreamlet[[i]][[j]]$adj.P.Val <0.5] <- 'TRUE'
  genelistNCvsC_dreamlet[[i]][[j]]$fdr_0.1 <- 'FALSE'
  genelistNCvsC_dreamlet[[i]][[j]]$fdr_0.1[genelistNCvsC_dreamlet[[i]][[j]]$adj.P.Val <0.1] <- 'TRUE'
  genelistNCvsC_dreamlet[[i]][[j]]$fdr_0.2 <- 'FALSE'
  genelistNCvsC_dreamlet[[i]][[j]]$fdr_0.2[genelistNCvsC_dreamlet[[i]][[j]]$adj.P.Val <0.2] <- 'TRUE'
}}

diff_express_df<- list()
for (i in names(genelistNCvsC_dreamlet)){for(j in names(genelistNCvsC_dreamlet[[i]])){
  genelistNCvsC_dreamlet[[i]][[j]] <- genelistNCvsC_dreamlet[[i]][[j]][order(genelistNCvsC_dreamlet[[i]][[j]]$adj.P.Val),]
  diff_express_df[[i]][[j]] <- data.frame(genelistNCvsC_dreamlet[[i]][[j]]$P.Value, genelistNCvsC_dreamlet[[i]][[j]]$logFC, rownames(genelistNCvsC_dreamlet[[i]][[j]]))
  names(diff_express_df[[i]][[j]]) <- c("pvalue","logFC","gene")
}
}
