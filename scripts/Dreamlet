for(i in names(FDR_sig_fgsea$Astrocyte)){
  FDR_sig_fgsea_refrmt[[i]] <- list(FDR_sig_fgsea$Inhibitory_CGE[[paste(i)]],FDR_sig_fgsea$Inhibitory_MGE[[paste(i)]],FDR_sig_fgsea$L2_3Excitatory[[paste(i)]],FDR_sig_fgsea$L5_6Excitatory[[paste(i)]],FDR_sig_fgsea$Astrocyte[[paste(i)]],FDR_sig_fgsea$Microglia[[paste(i)]],FDR_sig_fgsea$Oligodendrocytes[[paste(i)]],FDR_sig_fgsea$OPC[[paste(i)]],FDR_sig_fgsea$VLMC_Endo[[paste(i)]])
  names(FDR_sig_fgsea_refrmt[[i]]) <- names(FDR_sig_fgsea)
}
combine_df_CNV<- list()
FDR_sig_fgsea_drop<- list()
for(i in names(FDR_sig_fgsea_refrmt)){for(j in names(FDR_sig_fgsea_refrmt[[i]])){
  FDR_sig_fgsea_refrmt[[i]][[j]]$celltype <- paste(j) 
  FDR_sig_fgsea_refrmt[[i]][[j]]$CNV <- paste(i) 
  FDR_sig_fgsea_refrmt[[i]][[j]]$CNV <- sub(".*CNV" ,"",FDR_sig_fgsea_refrmt[[i]][[j]]$CNV)
  FDR_sig_fgsea_refrmt[[i]][[j]]$celltype<- revalue(FDR_sig_fgsea_refrmt[[i]][[j]]$celltype, c("Inhibitory_CGE"="CGE-Derived Inhibitory Neurons", "Inhibitory_MGE"="MGE-Derived Inhibitory Neurons","L2_3Excitatory" ="Upper Layer Excitatory Neurons","L5_6Excitatory"="Lower Layer Excitatory Neurons"))
}
  FDR_sig_fgsea_drop[[i]] <- list_drop_empty(FDR_sig_fgsea_refrmt[[i]])
  combine_df_CNV[[i]] <- Reduce(rbind,FDR_sig_fgsea_drop[[i]])
}

combine_df_bp <- list()
for(i in names(FDR_sig_fgsea_refrmt)){for(j in names(FDR_sig_fgsea_refrmt[[i]])){
  GO_ID_full <- sub(":.*","", FDR_sig_fgsea_refrmt[[i]][[j]]$pathway)
  GO_ID <- sub(".*GO","", GO_ID_full)
  GO_ID_edit <- paste("GO:", GO_ID, sep = "")
  FDR_sig_fgsea_refrmt[[i]][[j]]$GO_ID <- GO_ID_edit
  combine_df_bp[[i]][[j]] <- FDR_sig_fgsea_refrmt[[i]][[j]][FDR_sig_fgsea_refrmt[[i]][[j]]$GO_ID %in% df_bp$GOID,]
}}

fgseaRes_merge<- list()
for(i in names(fgsea_refrmt)){for(j in names(fgsea_refrmt[[i]])){
  fgsea_refrmt[[i]][[j]]$Celltype <- j
  fgsea_refrmt[[i]][[j]]$CNV <- i
  fgsea_refrmt[[i]][[j]]$CNV <- sub(".*CNV" ,"",fgsea_refrmt[[i]][[j]]$CNV)
  fgsea_refrmt[[i]][[j]]$celltype<- revalue(fgsea_refrmt[[i]][[j]]$celltype, c("Inhibitory_CGE"="CGE-Derived Inhibitory Neurons", "Inhibitory_MGE"="MGE-Derived Inhibitory Neurons","L2_3Excitatory" ="Upper Layer Excitatory Neurons","L5_6Excitatory"="Lower Layer Excitatory Neurons"))
}
  fgseaRes_merge[[i]] <- Reduce(rbind, fgsea_refrmt[[i]])
}

topterms<- list()
topterms_mergeCNV<- list()
for(i in names(combine_df_bp)){for(j in names(combine_df_bp[[i]])){
  topterms[[i]][[j]]<- combine_df_bp[[i]][[j]][order(combine_df_bp[[i]][[j]]$padj, decreasing = FALSE),][1:5,]
}
  topterms_mergeCNV[[i]] <- Reduce(rbind,topterms[[i]])
}
topterms_new <- Reduce(rbind,topterms_mergeCNV)
topterms_unique <- unique(topterms_new$pathway)

fgseaRes_merge_cd <- list()
for(i in names(fgseaRes_merge)){
  fgseaRes_merge_cd[[i]] <- fgseaRes_merge[[i]][fgseaRes_merge[[i]]$pathway %in% unique(topterms_mergeCNV[[i]]$pathway),]
}

fgseaRes_merge_cd_full <- Reduce(rbind,fgseaRes_merge_cd)

dput(levels(factor(fgseaRes_merge_cd_full$Celltype)))
fgseaRes_merge_cd_full$CNV<- factor(fgseaRes_merge_cd_full$CNV,levels = c("22q11.2 del", "22q11.2 dup","16p11.2 del", "16p11.2 dup","15q11.2 BP1-2 del", "15q11.2 BP1-2 dup", "1q21.1 del", "1q21.1 dup", "7q11.23 WBS del"))
fgseaRes_merge_cd_full$Celltype<- revalue(fgseaRes_merge_cd_full$Celltype, c("Inhibitory_CGE"="CGE-Derived Inhibitory Neurons", "Inhibitory_MGE"="MGE-Derived Inhibitory Neurons","L2_3Excitatory" ="Upper Layer Excitatory Neurons","L5_6Excitatory"="Lower Layer Excitatory Neurons"))
fgseaRes_merge_cd_full$Celltype<-  factor(fgseaRes_merge_cd_full$Celltype,levels = rev(c("VLMC_Endo", "OPC", "Oligodendrocytes", "Microglia", "Astrocyte", "Upper Layer Excitatory Neurons", "Lower Layer Excitatory Neurons", "MGE-Derived Inhibitory Neurons", "CGE-Derived Inhibitory Neurons")))
fgseaRes_merge_cd_full$FDR_Sig <- ""
fgseaRes_merge_cd_full$FDR_Sig[fgseaRes_merge_cd_full$padj <=0.1] <- "*"
fgseaRes_merge_cd_full$FDR_Sig[fgseaRes_merge_cd_full$padj <=0.01] <- "**"
fgseaRes_merge_cd_full$FDR_Sig[fgseaRes_merge_cd_full$padj <=0.001] <- "***"
fgseaRes_merge_cd_full$CNVGroup <- fgseaRes_merge_cd_full$CNV
fgseaRes_merge_cd_full$CNVGroup <- sub(" del.*","",fgseaRes_merge_cd_full$CNVGroup)
fgseaRes_merge_cd_full$CNVGroup <- sub(" dup.*","",fgseaRes_merge_cd_full$CNVGroup)
fgseaRes_merge_cd_full$Description <- sub(".*:","",fgseaRes_merge_cd_full$pathway)
fgseaRes_merge_cd_full$CNVType <- "Deletion"
fgseaRes_merge_cd_full$CNVType[grepl("dup",fgseaRes_merge_cd_full$CNV)] <- "Duplication"
fgseaRes_merge_cd_full$CNVGroup<- factor(fgseaRes_merge_cd_full$CNVGroup,levels = c( "22q11.2","16p11.2","15q11.2 BP1-2", "1q21.1", "7q11.23 WBS"
))
fgseaRes_merge_cd_full$CNVGroup<- as.factor(fgseaRes_merge_cd_full$CNVGroup)

png("fgsea_heatmap_FDR005_diffCNV_top5_split.png", width = 4300, height = 3300, res =130)
