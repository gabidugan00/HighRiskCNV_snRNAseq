res.gsa_H<- readRDS("/gpfs/gsfs12/users/HGBomics/GabiDugan/SNCNV_data_AdditionalSeqDec2022/February2023_Pipeline/scDblFinder/Adults/AfterDoubletRemoval/Harmony_MG/FilterClusters_PercentMT2_5/Harmony_MG/FilterClusters_PercentMT2/Harmony_MG/DifferentialGeneExpression/Dreamlet/DropSample30/Removed_MT_RiboGenes/~CNV+(1|Region)+(1|Match_group)+(1|HBCC_BrNum)/MsDB/res.gsa_H")

df <- list()
for(i in names(res.gsa_H)){
  # get genesets with FDR < 5%
  gs = unique(res.gsa_H[[i]]$Geneset[res.gsa_H[[i]]$FDR < 0.1])
  # keep only results of these genesets 
  df[[i]] = res.gsa_H[[i]][res.gsa_H[[i]]$Geneset %in% gs,]
  # plot results, but with no limit based on the highest/lowest t-statistic
}

for(i in names(df)){
  df[[i]]$assay <- revalue(df[[i]]$assay, c("Inhibitory_CGE"="CGE-Derived Inhibitory Neurons", "Inhibitory_MGE"="MGE-Derived Inhibitory Neurons","L2_3Excitatory" ="Lower Excitatory Neurons","L5_6Excitatory"="Upper Excitatory Neurons"))
  df[[i]]$assay <- factor(df[[i]]$assay,levels = rev(c("VLMC_Endo", "OPC", "Oligodendrocytes", "Microglia", "Astrocyte", "Upper Excitatory Neurons", "Lower Excitatory Neurons", "MGE-Derived Inhibitory Neurons", "CGE-Derived Inhibitory Neurons")))
}

for(i in names(df)){
  # plot results, but with no limit based on the highest/lowest t-statistic
  if(length(df[[i]]$assay)>0){
  png(paste(i,"zenith_MsDB.png"), width = 800, height = 1000, res = 100)
  plot1 <- plotZenithResults(df[[i]],5,1)+
    scale_y_discrete(labels = function(y) str_wrap(y, width = 25))
  grid.arrange(plot1)
  dev.off()
  }
}
