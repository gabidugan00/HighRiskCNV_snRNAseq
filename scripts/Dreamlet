for(i in names(res.proc_class)){
  data.frame.counts.remvdgenes[[i]]$Number.of.Genes <- nrow(res.proc_class[[i]])
  data.frame.counts.remvdgenes[[i]]$Cell.Type <- i
  data.frame.counts.remvdgenes[[i]]$Filtering <- "Dreamlet Default Settings"
}

