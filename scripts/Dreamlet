  rownames(genelistNCvsC_deseq[[i]][[j]]) <- genelistNCvsC_deseq[[i]][[j]]$gene
}}

names(genelistNCvsC_dreamlet) <- c("CNV15q11.2 BP1-2 dup","CNV22q11.2 del","CNV22q11.2 dup","CNV1q21.1 del","CNV1q21.1 dup","CNV16p11.2 del","CNV16p11.2 dup","CNV1q21.1 dup","CNV15q11.2 BP1-2 del","CNV15q11.2 BP1-2 dup","CNV1q21.1 dup","CNV7q11.23 WBS del","CNV7q11.23 WBS del")
