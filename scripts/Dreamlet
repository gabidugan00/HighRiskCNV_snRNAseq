  n <- length(metadata_simple[[i]]$BrainNumber)
  pval_covariates[[i]]=matrix(ncol=n, nrow=ncol(metadata_simple[[i]]))
  rownames(pval_covariates[[i]])=colnames(metadata_simple[[i]])
  colnames(pval_covariates[[i]])=paste0("PC",1:n)
}

for (i in names(pca_snCNV_dreamlet)) {for (PC in 1:ncol(pval_covariates[[i]])) {for (k in names(metadata_simple[[i]])){
  a=summary(lm(pca_snCNV_dreamlet[[i]]$x[,PC]~metadata_simple[[i]][[k]]))
  pval_covariates[[i]][k,PC]=pf(a$fstatistic[1],a$fstatistic[2],a$fstatistic[3],lower.tail=FALSE)[1]
}}}
