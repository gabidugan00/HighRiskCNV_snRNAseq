}
  t_values_df_comb[[i]] <- cbind(t_values_df[[i]][["CNV15q11.2 BP1-2 del"]],t_values_df[[i]][["CNV15q11.2 BP1-2 dup"]],t_values_df[[i]][["CNV16p11.2 del"]],t_values_df[[i]][["CNV16p11.2 dup"]],t_values_df[[i]][["CNV1q21.1 del"]],t_values_df[[i]][["CNV1q21.1 dup"]],t_values_df[[i]][["CNV22q11.2 del"]],t_values_df[[i]][["CNV22q11.2 dup"]],t_values_df[[i]][["CNV7q11.23 WBS del"]])
}

