genes_fdr_0.1_22q<- list()
genes_fdr_0.1_7q<- list()
split_genes_fdr_0.1_7q_22q<- list()
for(i in "CNV22q11.2 del"){for(j in names(genelistNCvsC_dreamlet_refrmt$`CNV22q11.2 del`)){ for(k in "CNV7q11.23 WBS del"){
  deletion_7q11_sig_genes[[k]][[j]] <- subset(genelistNCvsC_dreamlet_refrmt[[k]][[j]],fdr_0.1 == "TRUE")
  deletion_22q11_sig_genes[[k]][[j]] <- subset(genelistNCvsC_dreamlet_refrmt[[i]][[j]],fdr_0.1 == "TRUE")
  genes_fdr_0.1_22q[[j]] <- subset(genelistNCvsC_dreamlet_refrmt[[i]][[j]],gene.name %in% deletion_7q11_sig_genes[[k]][[j]]$gene.name & fdr_0.1 == "TRUE")
  genes_fdr_0.1_7q[[j]] <- subset(deletion_7q11_sig_genes[[k]][[j]],gene.name %in% genes_fdr_0.1_22q[[j]]$gene.name)
  genes_fdr_0.1_22q[[j]] <- genes_fdr_0.1_22q[[j]][ order(match(genes_fdr_0.1_22q[[j]]$gene.name, genes_fdr_0.1_7q[[j]]$gene.name)), ]
  genes_fdr_0.1_22q[[j]]$direction <- 'DIFFERENT'
  genes_fdr_0.1_22q[[j]]$direction[genes_fdr_0.1_22q[[j]]$diffexpressed == genes_fdr_0.1_7q[[j]]$diffexpressed] <- 'SAME'
  split_genes_fdr_0.1_7q_22q[[j]] <- split(genes_fdr_0.1_22q[[j]],genes_fdr_0.1_22q[[j]]$direction)
}}}

data.frame_fdr_0.1_7q_22q<- list()
data.frame_fdr_0.1_7q_22q.direction<- list()
for(i in names(split_genes_fdr_0.1_7q_22q)){for(j in names(split_genes_fdr_0.1_7q_22q[[i]])){
  data.frame_fdr_0.1_7q_22q[[i]][[j]] <- data_frame(nrow(split_genes_fdr_0.1_7q_22q[[i]][[j]]),length(union(deletion_22q11_sig_genes$`CNV22q11.2 del`[[i]]$gene.name, deletion_7q11_sig_genes$`CNV7q11.23 WBS del`[[i]]$gene.name)), i,j)
  names(data.frame_fdr_0.1_7q_22q[[i]][[j]]) <- c("Intersection","Union","Celltype","Direction")
}
  data.frame_fdr_0.1_7q_22q.direction[[i]] <- do.call(rbind, Map(data.frame, data.frame_fdr_0.1_7q_22q[[i]]))
}

data.frame_fdr_0.1_7q_22q.direction.celltype <- do.call(rbind, Map(data.frame, data.frame_fdr_0.1_7q_22q.direction))

png("cnv22q11_7q11_del_intersection_union_direction_fdr01.png")
plot1 <- ggplot(data.frame_fdr_0.1_7q_22q.direction.celltype, aes(x= Intersection, y = Celltype, fill= Direction))+
  geom_bar(position = "stack", stat="identity")+
  labs(title ="22q11 Deletion & 7q11 Deletion",subtitle = "Convergence & Divergence of FDR <0.1 Genes") + 
  theme(plot.title = element_text(hjust = 0.1), plot.subtitle = element_text(hjust=0.1))
plot2 <- ggplot(data.frame_fdr_0.1_7q_22q.direction.celltype, aes(x= Intersection/Union, y = Celltype, fill= Celltype))+
  geom_bar(position = "stack", stat="identity")+
  labs(title ="22q11 Deletion & 7q11 Deletion",subtitle = "Convergence & Divergence of FDR <0.1 Genes",
       x = "Intersection/Union") + 
  theme(plot.title = element_text(hjust = 0.1), plot.subtitle = element_text(hjust=0.1))
grid.arrange(plot1,plot2)
dev.off()

