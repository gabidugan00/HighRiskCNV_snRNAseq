df <- list()
for(i in names(res_zenith)){
  # get genesets with FDR < 10%
  gs = c("GO0006119: oxidative phosphorylation","GO0005746: mitochondrial respirasome","GO0036293: response to decreased oxygen levels","GO0006757: ATP generation from ADP" ,"GO0034599: cellular response to oxidative stress","GO0042775: mitochondrial ATP synthesis coupled electron transport","GO0061620: glycolytic process through glucose-6-phosphate")
  # keep only results of these genesets 
  df[[i]] = res_zenith[[i]][res_zenith[[i]]$Geneset %in% gs,]
  # plot results, but with no limit based on the highest/lowest t-statistic
  df[[i]]$t <- df[[i]]$delta/df[[i]]$se 
}

