limma_nomsig <- list()
deseq_nomsig<- list()
dreamlet_nomsig <- list()
for(i in names(genelistNCvsC_dreamlet)){for(j in names(genelistNCvsC_dreamlet[[i]])){
  limma_nomsig[[i]][[j]] <- subset(genelistNCvsC_dreamlet[[i]][[j]],P.Value <0.05)
  deseq_nomsig[[i]][[j]] <- subset(genelistNCvsC_deseq[[i]][[j]],pvalue <0.05)
  rownames(deseq_nomsig[[i]][[j]]) <- deseq_nomsig[[i]][[j]]$gene
  dreamlet_nomsig[[i]][[j]] <- subset(genelistNCvsC_dreamlet_refrmt[[i]][[j]], P.Value <0.05)
}}

intersection<- list()
union <- list()
intersect_union<- list()
for(i in names(limma_nomsig)){for(j in names(limma_nomsig[[i]])){
  intersection[[i]][[j]] <- Reduce(intersect, list(rownames(limma_nomsig[[i]][[j]]),rownames(deseq_nomsig[[i]][[j]]),rownames(deseq_nomsig[[i]][[j]])))
  union[[i]][[j]] <- Reduce(union, list(rownames(limma_nomsig[[i]][[j]]),rownames(deseq_nomsig[[i]][[j]]),rownames(deseq_nomsig[[i]][[j]])))
  intersect_union[[i]][[j]] <- length(intersection[[i]][[j]])/length(union[[i]][[j]])
}}
dreamlet_fdrsig <- list()
dreamlet_counts <- list()
for(i in names(genelistNCvsC_dreamlet_refrmt)){for(j in names(genelistNCvsC_dreamlet_refrmt[[i]])){
  dreamlet_fdrsig[[i]][[j]] <- subset(genelistNCvsC_dreamlet_refrmt[[i]][[j]],adj.P.Val <0.1)
}}

dreamlet_counts <- list()
for(i in names(dreamlet_fdrsig$`CNV22q11.2 del`)){
  dreamlet_counts[[i]] <- length(dreamlet_fdrsig$`CNV7q11.23 WBS del`[[i]]$logFC)
}

celltype <- c("Inhibitory_CGE", "Inhibitory_MGE", "L2_3Excitatory", "L5_6Excitatory", "Microglia", "Oligodendrocytes", "OPC", "VLMC_Endo")
counts <- rbind(dreamlet_counts$Astrocytes,dreamlet_counts$Inhibitory_CGE,dreamlet_counts$Inhibitory_MGE,dreamlet_counts$Microglia,dreamlet_counts$Oligodendrocytes,dreamlet_counts$OPC,dreamlet_counts$VLMC_Endo)
