Genes_inCNVregions <- readRDS("~/Genes_inCNVregions")
dreamlet_CNVgenes <- list(Genes_inCNVregions$HBCC_6_15q11del,Genes_inCNVregions$HBCC_6_15q11del,Genes_inCNVregions$HBCC_2_16p11del,Genes_inCNVregions$HBCC_8_16p11dup,Genes_inCNVregions$HBCC_1_1q21del,Genes_inCNVregions$HBCC_2_1q21dup,Genes_inCNVregions$SMRI_2_22q11del,Genes_inCNVregions$SMRI_3_22q11dup,Genes_inCNVregions$UMB_2_7q11del)
names(dreamlet_CNVgenes) <- names(genelistNCvsC_dreamlet$Astrocyte)

for (i in names(genelistNCvsC_dreamlet)){for (j in names(genelistNCvsC_dreamlet[[i]])){
  genelistNCvsC_dreamlet[[i]][[paste(j)]]$diffexpressed <- "NO"
  # if log2Foldchange > 0.2 and pvalue < 0.05, set as "UP" 
  genelistNCvsC_dreamlet[[i]][[j]]$diffexpressed[genelistNCvsC_dreamlet[[i]][[j]]$logFC > 0 & genelistNCvsC_dreamlet[[i]][[j]]$P.Value < 0.05] <- "UP"
  # if log2Foldchange < -0.2 and pvalue < 0.05, set as "DOWN"
  genelistNCvsC_dreamlet[[i]][[j]]$diffexpressed[genelistNCvsC_dreamlet[[i]][[j]]$logFC < 0 & genelistNCvsC_dreamlet[[i]][[j]]$P.Value < 0.05] <- "DOWN"
  genelistNCvsC_dreamlet[[i]][[j]]$CNVgene <- 'FALSE'
  genelistNCvsC_dreamlet[[i]][[j]]$CNVgene[rownames(genelistNCvsC_dreamlet[[i]][[j]]) %in% dreamlet_CNVgenes[[j]]$Gene.name] <- 'TRUE'
}}

for (i in names(genelistNCvsC_dreamlet)){for (j in names(genelistNCvsC_dreamlet[[i]])){
  genelistNCvsC_dreamlet[[i]][[paste(j)]]$diffexpressed <- "NO"
  # if log2Foldchange > 0.2 and pvalue < 0.05, set as "UP" 
  genelistNCvsC_dreamlet[[i]][[j]]$diffexpressed[genelistNCvsC_dreamlet[[i]][[j]]$logFC > 0 & genelistNCvsC_dreamlet[[i]][[j]]$P.Value < 0.05] <- "UP"
  # if log2Foldchange < -0.2 and pvalue < 0.05, set as "DOWN"
  genelistNCvsC_dreamlet[[i]][[j]]$diffexpressed[genelistNCvsC_dreamlet[[i]][[j]]$logFC < 0 & genelistNCvsC_dreamlet[[i]][[j]]$P.Value < 0.05] <- "DOWN"
  genelistNCvsC_dreamlet[[i]][[j]]$CNVgene <- 'FALSE'
  genelistNCvsC_dreamlet[[i]][[j]]$CNVgene[rownames(genelistNCvsC_dreamlet[[i]][[j]]) %in% dreamlet_CNVgenes[[j]]$Gene.name] <- 'TRUE'
}
}

for(i in names(genelistNCvsC_dreamlet)){for(j in names(genelistNCvsC_dreamlet[[i]])){
  genelistNCvsC_dreamlet[[i]][[j]]$fdr_0.5 <- 'FALSE'
  genelistNCvsC_dreamlet[[i]][[j]]$fdr_0.5[genelistNCvsC_dreamlet[[i]][[j]]$adj.P.Val <0.5] <- 'TRUE'
  genelistNCvsC_dreamlet[[i]][[j]]$fdr_0.1 <- 'FALSE'
  genelistNCvsC_dreamlet[[i]][[j]]$fdr_0.1[genelistNCvsC_dreamlet[[i]][[j]]$adj.P.Val <0.1] <- 'TRUE'
  genelistNCvsC_dreamlet[[i]][[j]]$fdr_0.2 <- 'FALSE'
  genelistNCvsC_dreamlet[[i]][[j]]$fdr_0.2[genelistNCvsC_dreamlet[[i]][[j]]$adj.P.Val <0.2] <- 'TRUE'
}}

for (i in names(genelistNCvsC_dreamlet)){for(j in names(genelistNCvsC_dreamlet[[i]])){
  genelistNCvsC_dreamlet[[i]][[j]]$gene.name <- rownames(genelistNCvsC_dreamlet[[i]][[j]])
}}

library(tidyr)
DEG_dream <- list()
DEG_count<- list()
for (i in names(genelistNCvsC_dreamlet)){for(j in names(genelistNCvsC_dreamlet[[i]])){
  print(i)
  print(j)
  DEG_dream[[i]][[j]] <- subset(genelistNCvsC_dreamlet[[i]][[j]], diffexpressed != "NO")
  DEG_dream[[i]][[j]]$Key <- paste(DEG_dream[[i]][[j]]$diffexpressed,DEG_dream[[i]][[j]]$fdr_0.1, sep = "_")
  DEG_dream[[i]][[j]] <- DEG_dream[[i]][[j]] %>%
    dplyr::group_by(Key)%>%
    dplyr::count()
  DEG_dream[[i]][[j]]$Celltype <- i
  DEG_dream[[i]][[j]]$group <-j
}
  DEG_count[[i]] <- do.call(rbind, Map(data.frame, DEG_dream[[i]]))
}

DEG_dream_merge <- do.call(rbind, Map(data.frame,DEG_count))
library(plyr)
DEG_dream_merge$Key <- revalue(DEG_dream_merge$Key, c("DOWN_FALSE"="Downregulated", "DOWN_TRUE"="Downregulated (FDR <0.1)","UP_FALSE" ="Upregulated","UP_TRUE"="Upregulated (FDR<0.1)"))
DEG_dream_merge$Celltype <- revalue(DEG_dream_merge$Celltype, c("Inhibitory_CGE"="CGE-Derived Inhibitory Neurons", "Inhibitory_MGE"="MGE-Derived Inhibitory Neurons","L2_3Excitatory" ="Upper Layer Excitatory Neurons","L5_6Excitatory"="Lower Layer Excitatory Neurons"))
dput(levels(as.factor(DEG_dream_merge$Celltype)))
DEG_dream_merge$Celltype <- factor(DEG_dream_merge$Celltype,levels = c("VLMC_Endo", "OPC", "Oligodendrocytes", "Microglia", "Astrocyte", "Upper Layer Excitatory Neurons", "Lower Layer Excitatory Neurons", "MGE-Derived Inhibitory Neurons", "CGE-Derived Inhibitory Neurons"))
dput(levels(as.factor(DEG_dream_merge$group)))
DEG_dream_merge$group <- factor(DEG_dream_merge$group,levels = c("CNV22q11.2 del", "CNV22q11.2 dup","CNV16p11.2 del", "CNV16p11.2 dup", "CNV7q11.23 WBS del","CNV1q21.1 del", "CNV1q21.1 dup","CNV15q11.2 BP1-2 del", "CNV15q11.2 BP1-2 dup"))
dput(levels(as.factor(DEG_dream_merge$Key)))

library(ggplot2)
png("dreamlet_barplot_FDR_allCNVs_order.png", width = 3500, height = 1550, res = 250)
ggplot2::ggplot(data = DEG_dream_merge, aes(Celltype, n, fill = Key)) +
  geom_bar(position = "stack", stat="identity")+
  scale_fill_manual(values=c("firebrick1","firebrick3","dodgerblue","dodgerblue4"))+
