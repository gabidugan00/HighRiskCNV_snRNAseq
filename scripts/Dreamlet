library(SingleCellExperiment)
snCNV_spx_nd_adult_MG_fc_MG_fc_MG <- readRDS("/gpfs/gsfs12/users/HGBomics/GabiDugan/SNCNV_data_AdditionalSeqDec2022/February2023_Pipeline/scDblFinder/Adults/AfterDoubletRemoval/Harmony_MG/FilterClusters_PercentMT2_5/Harmony_MG/FilterClusters_PercentMT2/Harmony_MG/snCNV_spx_nd_adult_MG_fc_MG_fc_MG")
table(snCNV_spx_nd_adult_MG_fc_MG_fc_MG$orig.ident)
sce <- as.SingleCellExperiment(snCNV_spx_nd_adult_MG_fc_MG_fc_MG)
gc()
sce <- sce[,-grep("Sample_30", colnames(sce))]
rm(snCNV_spx_nd_adult_MG_fc_MG_fc_MG)
table(sce$cell.class.annotation)

pb_class <- aggregateToPseudoBulk(sce,
                            assay = "counts",     
                            cluster_id = "cell.class.annotation",  
                            sample_id = "orig.ident", 
                            BPPARAM = SnowParam(6, progressbar=TRUE))
pb_class <- pb_class[-grep("RPL",rownames(pb_class)),]
pb_class <- pb_class[-grep("MT-",rownames(pb_class)),]
pb_class <- pb_class[-grep("RPS",rownames(pb_class)),]
pb_class$CNV <-  relevel(factor(pb_class$CNV), ref= "non-carrier")
form <- ~CNV + (1|Region) + (1 | HBCC_BrNum) + (1 | Match_group)
# Normalize and apply voom/voomWithDreamWeights
res.proc_class = processAssays( pb_class, form)
saveRDS(res.proc_class,"/data/HGBomics/GabiDugan/SNCNV_data_AdditionalSeqDec2022/February2023_Pipeline/scDblFinder/Adults/AfterDoubletRemoval/Harmony_MG/FilterClusters_PercentMT2_5/Harmony_MG/FilterClusters_PercentMT2/Harmony_MG/DifferentialGeneExpression/Dreamlet/DropSample30/Removed_MT_RiboGenes/Pseudobulking_CellClass/res.proc_class")
