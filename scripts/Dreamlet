oxphos_genes_FDR<- list()
oxphos_genes_t<- list()
oxphos_genes_t_merge<- list()
for(i in names(genelistNCvsC_dreamlet_FDR)){for(j in names(genelistNCvsC_dreamlet_FDR[[i]])){
  oxphos_genes_FDR[[i]][[j]] <- subset(genelistNCvsC_dreamlet_FDR[[i]][[j]],genelistNCvsC_dreamlet_FDR[[i]][[j]]$gene.name %in% genes)
  oxphos_genes_t[[i]][[j]] <- subset(genelistNCvsC_dreamlet_t[[i]][[j]],genelistNCvsC_dreamlet_t[[i]][[j]]$gene.name %in% genes)
}
  oxphos_genes_t_merge[[i]] <- Reduce(rbind,oxphos_genes_t[[i]])
}
