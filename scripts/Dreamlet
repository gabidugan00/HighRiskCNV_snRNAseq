  geom_bar(stat="identity", position=position_dodge())+
  labs(title ="Dreamlet Number of Genes By Cell Class",subtitle = "Default Settings") + 
  theme_cowplot()+
  theme(plot.title = element_text(hjust = 0.5), plot.subtitle = element_text(hjust=0.5))+
  geom_text(aes(label=Number.of.Genes, color = Cell.Type), position=position_dodge(width=0.9), vjust=0.5, hjust = 0)+
  xlim(0,25000)+
