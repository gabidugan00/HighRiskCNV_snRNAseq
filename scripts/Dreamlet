cormat <- list()
melted_cormat<- list()
for(i in names(t_values_df_comb)){
  t_value_matrix[[i]] <- as.matrix(t_values_df_comb[[i]])
  cormat[[i]] <- cor(t_value_matrix[[i]])
  melted_cormat[[i]] <- melt(cormat[[i]])
  melted_cormat[[i]]$celltype <- i
}

for(i in names(melted_cormat)){for(j in names(melted_cormat[[i]])){
  print(paste("melted_cormat[[i]][[",j,"]],", sep = ''), quote= FALSE)
}}

reorder_cormat <- function(cormat){
  # Use correlation between variables as distance
  dd <- as.dist((1-cormat)/2)
  hc <- hclust(dd)
  cormat <-cormat[hc$order, hc$order]
}

for(i in names(cormat)){
  cormat[[i]] <- reorder_cormat(cormat[[i]])
  melted_cormat[[i]] <- melt(cormat[[i]])
}

for(i in names(melted_cormat)){
  plot1 <- ggplot(data = melted_cormat[[i]], aes(x=Var1, y=Var2, fill=value)) + 
    geom_tile()+
    ggtitle(paste(i))+
    theme(axis.text.x = element_text(angle = 90, vjust = 0.5, hjust=1))+
    theme(plot.title = element_text(hjust = 0.5))+
    scale_fill_gradient2(low=muted("blue"), mid = "white",high=muted("red"),na.value = "red",
                         breaks=seq(-0.1,0.2,0.05), #breaks in the scale bar
                         limits=c(-0.1,0.2))
  png(paste("t_values_drmlt_heatmap_reorder",i,j,".png", sep = "_"), width = 1200, height = 1000, res = 120)
  grid.arrange(plot1)
  dev.off()
}


