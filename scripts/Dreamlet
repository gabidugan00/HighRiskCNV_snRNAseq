genelistNCvsC_dreamlet_FDR <- list()
for(i in names(genelistNCvsC_dreamlet)){for(j in names(genelistNCvsC_dreamlet[[i]])){
  genelistNCvsC_dreamlet_FDR[[i]][[j]] <- subset(genelistNCvsC_dreamlet[[i]][[j]],adj.P.Val <0.1)
}}

for(i in names(genelistNCvsC_dreamlet_FDR)){for (j in names(genelistNCvsC_dreamlet_FDR[[i]])){
  genelistNCvsC_dreamlet_FDR[[i]][[j]]$DCIS_1 <- genelistNCvsC_dreamlet_FDR[[i]][[j]]$logFC
}}

library(pathview)
for(i in names(genelistNCvsC_dreamlet_FDR)){for(j in names(genelistNCvsC_dreamlet_FDR[[i]])){
  datagene <- rownames(genelistNCvsC_dreamlet_FDR[[i]][[j]])
  dataFold <- subset(genelistNCvsC_dreamlet_FDR[[i]][[j]], select ="logFC" )
  df <- data.frame(matrix(ncol = 2, nrow = length(datagene)))
  datageneORF <-unlist(datagene)
  dataFoldun = unlist(dataFold)
  df[1] = datagene
  df[2] = dataFoldun
  rownames(df) = make.names(df[,1], unique=TRUE)
  df[,1] <- NULL
  if(nrow(df)>0){
  pv.out <- pathview(gene.data = df, pathway.id = "00190",gene.idtype="symbol",species = "hsa", out.suffix = paste(i,j,"oxphos_FDR", sep = "_"))
  }
}}

df <- list()
for(i in names(genelistNCvsC_dreamlet_FDR)){for(j in names(genelistNCvsC_dreamlet_FDR[[i]])){
  datagene <- rownames(genelistNCvsC_dreamlet_FDR[[i]][[j]])
  dataFold <- subset(genelistNCvsC_dreamlet_FDR[[i]][[j]], select ="logFC")
  df[[i]][[j]] <- data.frame(matrix(ncol = 2, nrow = length(datagene)))
  datageneORF <-unlist(datagene)
  dataFoldun = unlist(dataFold)
  df[[i]][[j]][1] = datagene
  df[[i]][[j]][2] = dataFoldun
  rownames(df[[i]][[j]]) = make.names(df[[i]][[j]][,1], unique=TRUE)
  df[[i]][[j]][,1] <- NULL
  if(nrow(df[[i]][[j]])>0){
    pv.out <- pathview(gene.data = df[[i]][[j]], pathway.id = "00010",gene.idtype="symbol",species = "hsa", out.suffix = paste(i,j,"glycosis_FDR", sep = "_"))
  }
}}


