cell.countsample <- split(cell.counts,cell.counts$snCNV_spx_nd_adult_MG_fc_MG_fc_MG.orig.ident)
counts <- list()
for(i in names(cell.countsample)){
  counts[[i]] <- data_frame(sum(cell.countsample[[i]]$n),i)
  names(counts[[i]]) <- c("cell.count","orig.ident")
}

counts <- do.call(rbind, Map(data.frame, counts))

pb_adult_dreamlet <-readRDS("/gpfs/gsfs12/users/HGBomics/GabiDugan/SNCNV_data_AdditionalSeqDec2022/February2023_Pipeline/scDblFinder/Adults/AfterDoubletRemoval/Harmony_MG/FilterClusters_PercentMT2_5/Harmony_MG/FilterClusters_PercentMT2/Harmony_MG/DifferentialGeneExpression/Dreamlet/DropSample30/pb_adult_dreamlet")
pb_adult_dreamlet$cell.counts <- counts$cell.count[match(colnames(pb_adult_dreamlet), counts$orig.ident)]
pb_adult_dreamlet$CNV <-  relevel(factor(pb_adult_dreamlet$CNV), ref= "non-carrier")
form <- ~CNV + cell.counts+(1|Region) + (1 | HBCC_BrNum) + (1 | Match_group)

# Normalize and apply voom/voomWithDreamWeights
res.proc_defaults_cellcount = processAssays(pb_adult_dreamlet, form, min.cells=0)
res.proc_defaults_cellcount<- readRDS("/gpfs/gsfs12/users/HGBomics/GabiDugan/SNCNV_data_AdditionalSeqDec2022/February2023_Pipeline/scDblFinder/Adults/AfterDoubletRemoval/Harmony_MG/FilterClusters_PercentMT2_5/Harmony_MG/FilterClusters_PercentMT2/Harmony_MG/DifferentialGeneExpression/Dreamlet/DropSample30/~CNV+cell.counts+(1|Region)+(1|HBCC_BrNum)+(1|Match_group)/res.proc_defaults_cellcount")

res.proc_defaults_cellcount$Astrocyte 
res.dl_defaults_cellcount <- dreamlet(res.proc_defaults_cellcount, form)
