cnv22q11_mirror <- list(genelistNCvsC_dreamlet_refrmt$`CNV22q11.2 del`,genelistNCvsC_dreamlet_refrmt$`CNV22q11.2 dup`)
names(cnv22q11_mirror) <- c("CNV22q11.2 del","CNV22q11.2 dup")

cnv22q11_mirror_chromosome <- list()
for(i in names(cnv22q11_mirror)){for(j in names(cnv22q11_mirror[[i]])){
  cnv22q11_mirror[[i]][[j]]$Direction <- "UP"
  cnv22q11_mirror[[i]][[j]]$Direction[cnv22q11_mirror[[i]][[j]]$logFC < 0 ] <- "DOWN"
  cnv22q11_mirror$`CNV22q11.2 del`[[j]]<- cnv22q11_mirror$`CNV22q11.2 del`[[j]][match(rownames(cnv22q11_mirror$`CNV22q11.2 dup`[[j]]),rownames(cnv22q11_mirror$`CNV22q11.2 del`[[j]])),]
  cnv22q11_mirror_chromosome[[i]][[j]] <- split(cnv22q11_mirror[[i]][[j]],cnv22q11_mirror[[i]][[j]]$chromosome)
  cnv22q11_mirror_chromosome[[i]][[j]]<- cnv22q11_mirror_chromosome[[i]][[j]][sort(names(cnv22q11_mirror_chromosome[[i]][[j]]), decreasing = FALSE)] 
}}

cnv22q11_dir_df <- list()
for(j in names(cnv22q11_mirror_chromosome[[i]])){for(k in 1:22){
  cnv22q11_dir_df[[j]][[k]] <- table(cnv22q11_mirror_chromosome$`CNV22q11.2 del`[[j]][[k]]$Direction ==  cnv22q11_mirror_chromosome$`CNV22q11.2 dup`[[j]][[k]]$Direction)
}
  names(cnv22q11_dir_df[[j]]) <- names(cnv22q11_mirror_chromosome$`CNV22q11.2 del`[[j]][1:22])
}


for(i in names(cnv22q11_dir_df)){
  names(cnv22q11_dir_df[[i]]) <- c("chromosome_ 1","chromosome_ 2","chromosome_ 3","chromosome_ 4","chromosome_ 5","chromosome_ 6","chromosome_ 7","chromosome_ 8","chromosome_ 9","chromosome_ 10","chromosome_ 11","chromosome_ 12","chromosome_ 13","chromosome_ 14","chromosome_ 15","chromosome_ 16","chromosome_ 17","chromosome_ 18","chromosome_ 19","chromosome_ 20","chromosome_ 21","chromosome_ 22")
}
