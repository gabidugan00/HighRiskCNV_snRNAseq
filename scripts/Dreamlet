  genelist_nonCNV <- subset(genelistNCvsC_dreamlet_refrmt[[paste(i)]][[j]], genelistNCvsC_dreamlet_refrmt[[paste(i)]][[j]]$CNVgene == "FALSE")
  genelist_CNV <- subset(genelistNCvsC_dreamlet_refrmt[[paste(i)]][[j]], genelistNCvsC_dreamlet_refrmt[[paste(i)]][[j]]$CNVgene == "TRUE")
  ggplot_volcano[[j]] <- ggplot(data=genelist_nonCNV, aes(x=logFC, y=-log10(P.Value))) +
    geom_point(color= "grey") + 
    theme_minimal() +
    scale_color_manual(values=c("grey")) +
    ggtitle(paste(j, sep=' '))+
    ylim(-0.05,7)+
    theme_cowplot()+
    theme(plot.title = element_text(hjust=0.5, size = 15))+
    geom_hline(yintercept=-log10(0.05),linetype="dashed", color = "blue")+
    geom_point(data=genelist_CNV, aes(x=logFC, y=-log10(P.Value)), color = "red", size =3)
}
  names(genelistNCvsC_dreamlet_refrmt$`CNV15q11.2 BP1-2 del`)
  volcano_plots[[paste(i)]] <- ggplot_volcano
  png(paste("dreamlet_volcano_label",i,".png"), width = 4000, height=900, res = 120)
  grid.arrange(volcano_plots[[paste(i)]]$`CGE-Derived Inhibitory Neurons`,volcano_plots[[paste(i)]]$`MGE-Derived Inhibitory Neurons`,volcano_plots[[paste(i)]]$`Lower Excitatory Neurons`,volcano_plots[[paste(i)]]$`Upper Excitatory Neurons`,volcano_plots[[paste(i)]]$Astrocyte,volcano_plots[[paste(i)]]$Microglia,volcano_plots[[paste(i)]]$Oligodendrocytes,volcano_plots[[paste(i)]]$OPC,volcano_plots[[paste(i)]]$VLMC_Endo, ncol = 9,top=textGrob(paste(i), gp=gpar(fontsize=20)))
  dev.off()
}


