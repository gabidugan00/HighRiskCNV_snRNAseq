  metadata$subtype.counts <-  cell.counts$n[match(metadata$orig.ident_subclass.annotation,cell.counts$orig.ident_subclass.annotation)]
  metadata$Reads.Mapped.Confidently.to.Transcriptome <- snCNV_adult_metadata$Reads.Mapped.Confidently.to.Transcriptome[match(metadata$sample_id , snCNV_adult_metadata$orig.ident)]
  metadata$Median.Genes.per.Cell.bycelltype <- median.genes.sample.celltype.mg$median.genes.use.bysample..i....j....k...[match(metadata$orig.ident_subclass.annotation , median.genes.sample.celltype.mg$orig.ident_subclass.annotation)]
  metadata$Mean.Genes.per.Cell.bycelltype <- mean.genes.sample.celltype.mg$mean.genes.use.bysample..i....j....k...[match(metadata$orig.ident_subclass.annotation , mean.genes.sample.celltype.mg$orig.ident_subclass.annotation)]
  metadata$HBCC_BrNum <- snCNV_adult_metadata$HBCC_BrNum[match(metadata$sample_id , snCNV_adult_metadata$orig.ident)]
  metadata_simple[[i]] <- metadata[,c("HBCC_BrNum","Match_group","Region","CNV","Age","pH","PMI","bulk_RIN","Estimated.Number.of.Cells","Sequencing.Saturation","Reads.Mapped.Confidently.to.Genome","Reads.Mapped.Confidently.to.Intergenic.Regions","Reads.Mapped.Confidently.to.Intronic.Regions","Reads.Mapped.Confidently.to.Exonic.Regions","Reads.Mapped.Confidently.to.Transcriptome","subtype.counts","Median.Genes.per.Cell.bycelltype","Mean.Genes.per.Cell.bycelltype")]
