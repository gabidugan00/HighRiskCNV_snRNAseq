    CNVGroup <- factor(
      CNVGroup,
      levels = c("22q11.2", "16p11.2", "15q11.2", "1q21.1","7q11.23")
    )
  )
fgseaRes_merge_cd_full$CNVGroup<- factor(
  fgseaRes_merge_cd_full$CNVGroup,
