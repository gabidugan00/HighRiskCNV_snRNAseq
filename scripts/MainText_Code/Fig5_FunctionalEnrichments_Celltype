# Load GO data and filter for biological process (BP) terms
go <- keys(GO.db, keytype = "GOID")
df_bp <- AnnotationDbi::select(GO.db, columns = c("GOID", "TERM"), keys = "BP", keytype = "ONTOLOGY")

#PART 1: Top terms by celltype
# Filter significant pathways (FDR < 0.050)
FDR_sig_fgsea <- lapply(fgseaRes, function(celltype_res) {
  lapply(celltype_res, function(cnv_res) {
    subset(cnv_res, padj < 0.05)
  })
})

# Merge significant fgsea results by cell type
FDR_sig_merge <- lapply(names(FDR_sig_fgsea), function(celltype) {
  lapply(names(FDR_sig_fgsea[[celltype]]), function(cnv) {
    if (nrow(FDR_sig_fgsea[[celltype]][[cnv]]) > 0) {
      data <- FDR_sig_fgsea[[celltype]][[cnv]]
      data <- data %>%
        mutate(CNV = str_remove_all(CNV, ".*CNV|WBS |BP1-2 "))
      return(data)
    }
    NULL
  }) %>% compact() %>% bind_rows()
})
names(FDR_sig_merge) <- names(FDR_sig_fgsea)

# Filter for BP terms
FDR_sig_merge_BP <- lapply(FDR_sig_merge, function(data) {
  if (!is.null(data)) {
    GO_ID_full <- sub(":.*", "", data$pathway)
    GO_ID <- sub(".*GO", "", GO_ID_full)
    GO_ID_edit <- paste("GO:", GO_ID, sep = "")
    data$GO_ID <- GO_ID_edit
    data <- data[data$GO_ID %in% df_bp$GOID, ]
    return(data)
  }
  NULL
})

# Analyze pathway convergence and compute summary statistics
topterms <- lapply(FDR_sig_merge_BP, function(data) {
  if (!is.null(data)) {
    freq <- data %>%
      dplyr::group_by(pathway) %>%
      dplyr::summarise(Frequency = n(), .groups = "drop")
    
    log_padj_sum <- data %>%
      dplyr::group_by(pathway) %>%
      dplyr::summarise(SumLogPadj = sum(log(padj)), .groups = "drop")
    
    combined <- left_join(freq, log_padj_sum, by = "pathway") %>%
      dplyr::arrange(desc(Frequency), SumLogPadj)%>%
      dplyr::slice_head(n=5)
    
    return(combined)
  }
  NULL
})

# Merge results for plotting
fgseaRes_merge <- lapply(names(fgseaRes), function(celltype) {
  lapply(names(fgseaRes[[celltype]]), function(cnv) {
    if (nrow(fgseaRes[[celltype]][[cnv]]) > 0) {
      data <- fgseaRes[[celltype]][[cnv]]
      data <- data[data$pathway %in% topterms[[celltype]]$pathway, ]
      data$celltype <- recode(celltype,
                              "Inhibitory_CGE" = "CGE-Derived Inhibitory Neurons",
                              "Inhibitory_MGE" = "MGE-Derived Inhibitory Neurons",
                              "L2_3Excitatory" = "Upper Layer Excitatory Neurons",
                              "L5_6Excitatory" = "Lower Layer Excitatory Neurons",
                              "Oligodendrocytes" = "Oligos")
      data <- data %>%
        mutate(
        CNV = str_remove_all(CNV, ".*CNV|WBS |BP1-2 "))
      return(data)
    }
    NULL
  }) %>% compact() %>% bind_rows()
})

names(fgseaRes_merge) <- names(fgseaRes)

fgseaRes_merge2 <- Reduce(rbind, fgseaRes_merge)

fgseaRes_merge_cd_full <- fgseaRes_merge2 %>%
  mutate(
    FDR_Sig = case_when(
      padj <= 0.001 ~ "***",
      padj <= 0.01 ~ "**",
      padj <= 0.05 ~ "*",
      TRUE ~ ""
    ),
    CNVType = ifelse(grepl("dup", CNV), "DUP", "DEL"),
    CNVGroup = str_replace(CNV, " (del|dup).*", ""),
    Description = str_extract(pathway, ":.*") %>% sub(":", "", .),
    celltype = factor(celltype, levels = rev(c(
      "VLMC_Endo", "OPC", "Oligos", "Microglia", "Astrocyte",
      "Upper Layer Excitatory Neurons", "Lower Layer Excitatory Neurons",
      "MGE-Derived Inhibitory Neurons", "CGE-Derived Inhibitory Neurons"
