# Define a function to extract pathway-specific genes
extract_pathway_genes <- function(go_id, genelist) {
  genes <- sort(geneIds(go.gs[[go_id]]))
  subset_data <- genelist %>%
    dplyr::filter(gene.name %in% genes) 
  return(subset_data)
}

# Rename celltype labels
relabel_celltypes <- function(df) {
  revalue(df$celltype, c(
    "Inhibitory_CGE" = "CGE-Derived Inhibitory Neurons",
    "Inhibitory_MGE" = "MGE-Derived Inhibitory Neurons",
    "L2_3Excitatory" = "Upper Layer Excitatory Neurons",
    "L5_6Excitatory" = "Lower Layer Excitatory Neurons"
  ))
}

