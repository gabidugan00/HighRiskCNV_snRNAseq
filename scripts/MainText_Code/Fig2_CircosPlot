make_circos_single_cluster <- function(
    plot_df,
    cluster_colors,
    CNV_colors,
    celltype_colors,
    chosen_cluster,
    pdf_file = "circos_single_cluster.pdf",
    width = 16,
    height = 16
) {
  
  plot_df$label_new = sub("__"," ",plot_df$label)
  sectors <- plot_df$label_new
  
  sector_clusters  <- setNames(plot_df$cluster,  plot_df$label_new)
  sector_CNVs      <- setNames(plot_df$cnv, plot_df$label_new)
  sector_celltypes <- setNames(plot_df$celltype, plot_df$label_new)
  #Empty block so then I can add the annotations
  empty_label <- "__EMPTY__"
  sectors <- c(sectors, empty_label)
  sector_clusters  <- c(sector_clusters,  setNames("empty", empty_label))
  sector_CNVs      <- c(sector_CNVs,      setNames("empty", empty_label))
  sector_celltypes <- c(sector_celltypes, setNames("empty", empty_label))
  cluster_colors["empty"]  <- NA
  celltype_colors["empty"] <- NA
  CNV_colors["empty"]      <- NA
  
  cluster_sectors <- plot_df |> 
    dplyr::filter(cluster == chosen_cluster) |> 
    dplyr::pull(label_new)
  
  link_color <- adjustcolor(cluster_colors[as.character(chosen_cluster)], alpha.f = 0.6)
  
  pdf(pdf_file, width = width, height = height)
  par(mar = c(8,8,8,8))
  circos.clear()
  circos.initialize(factors = sectors, xlim = c(0, 1))
  circos.par(
    start.degree = 90,
    gap.degree = 0.5,
    cell.padding = c(0,0,0,0),
    track.margin = c(0,0)
  )
  
  #Rings: Cluster -> Celltype -> CNV
  circos.trackPlotRegion(
    factors = sectors, ylim = c(0,1),
    bg.col =cluster_colors[as.character(sector_clusters)],
    track.height = 0.08,
    bg.border = NA,
    track.margin = c(0.005, 0.005)
  )
  circos.trackPlotRegion(
    factors = sectors, ylim = c(0,1),
    bg.col = celltype_colors[as.character(sector_celltypes)],
    track.height = 0.10,
    bg.border = NA,
    track.margin = c(0.005, 0.005)
  )
  
  circos.trackPlotRegion(
    factors = sectors, ylim = c(0,1),
    bg.col = CNV_colors[as.character(sector_CNVs)],
    track.height = 0.25,
    bg.border = NA,
    track.margin = c(0.005, 0.005)
  )
  # label_offset <- 0.8    
  # label_y <- 1 + label_offset
  # 
  # for(sector in sectors) {
  #   circos.text(
  #     x = 0.5,
  #     y = label_y,
  #     labels = sector_celltypes[sector], 
  #     sector.index = sector,
  #     facing = "clockwise",
  #     niceFacing = TRUE,
  #     adj = c(0, 0.5),
  #     cex = 1,
  #     font = 2
  #   )
  # }

  if (length(cluster_sectors) > 1) {
    for (i in 1:(length(cluster_sectors) - 1)) {
      for (j in (i+1):length(cluster_sectors)) {
        circos.link(
          cluster_sectors[i], 0.5,
          cluster_sectors[j], 0.5,
          col = link_color,
          border = NA,
          h.ratio = 0.2 
        )
      }
    }
  }
  
  dev.off()
}

